<!DOCTYPE html>
<html>
<head>
<style>
  /* 1. 이미지를 감싸는 컨테이너 */
  .image-container {
    position: relative;
    width: 1024px; /* 원하는 이미지 폭 */
    height: 1024px; /* 원하는 이미지 높이 */
  }

  /* 2. 겹쳐질 이미지 기본 설정 */
  .image-container img {
    position: absolute; /* 절대 위치 지정 */
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* 이미지가 찌그러지지 않게 설정 */
  }

  /* 3. 위쪽에 올 이미지 (투명도 조절 등 가능) */
  .overlay-image {
    z-index: 10; /* 숫자가 클수록 위로 올라옴 */
    /* 필요시 투명도 조절: opacity: 0.5; */
  }
</style>
</head>
<body>

<div class="image-container">
  <!-- 아래에 깔릴 이미지 -->
  <img src="https://itimg.kr/3934/WH/ST.webp
" alt="배경 이미지">
  <!-- 위에 겹칠 이미지 -->
  <img src="https://itimg.kr/3934/PJ/BF1.webp" alt="위에 겹칠 이미지" class="overlay-image">
</div>

</body>
</html>
